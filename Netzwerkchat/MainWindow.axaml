<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Netzwerkchat.MainWindow"
        Title="Netzwerkchat"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
  <Grid ColumnDefinitions="300,*"
        Background="#0F172A">
    <Border Background="#111827"
            Padding="22">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Spacing="10"
                    Margin="0,0,0,18">
          <Border Width="56"
                  Height="56"
                  Background="#2563EB"
                  CornerRadius="18"
                  HorizontalAlignment="Left">
            <TextBlock Text="N"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
              <TextBlock x:Name="UsernameText"
                 Text="USERNAME"
                     FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="White" />
              <TextBlock x:Name="StatusText"
                 Text="STATUS: Online"
                     Foreground="#94A3B8"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Border Background="#1E293B"
                CornerRadius="18"
                Padding="8">
          <StackPanel>
            <TextBlock Text="Buddies"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="16" />
            <ListBox x:Name="BuddyList"
                     ItemsSource="{Binding Buddies}"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Background="#0F172A"
                          CornerRadius="28"
                          Padding="1"
                          Margin="0,0,0,3">
                    <Grid ColumnDefinitions="46,*">
                      <Border Width="46"
                              Height="46"
                              Background="#2563EB"
                              CornerRadius="23">
                        <TextBlock Text="{Binding AvatarText}"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>

                      <StackPanel Grid.Column="1"
                                  Spacing="2"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding BuddyName}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding BuddyStatus}"
                                   Foreground="#94A3B8"
                                   FontSize="12" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Background="#F8FAFC"
            CornerRadius="28"
            Margin="18"
            Padding="22">
      <Grid RowDefinitions="Auto,*,Auto">
        <Border Background="#FFFFFF"
                CornerRadius="20"
            Padding="18"
            Margin="0,0,0,16">
          <StackPanel Spacing="6">
            <TextBlock Text="Chat"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock x:Name="ChatTopicText"
                       Text="Broadcast"
                       Foreground="#64748B" />
          </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                CornerRadius="20"
          Padding="18"
          Margin="0,0,0,16">
          <ListBox x:Name="MessagesList"
                   ItemsSource="{Binding Messages}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="{Binding BubbleBackground}"
                        CornerRadius="18"
                        Padding="14"
                        Margin="0,0,0,12"
                        MaxWidth="680"
                        HorizontalAlignment="{Binding BubbleAlignment}">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Sender}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{Binding BubbleForeground}" />
                    <TextBlock Text="{Binding MessageContent}"
                               TextWrapping="Wrap"
                               Foreground="{Binding BubbleForeground}"
                               FontSize="14" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                CornerRadius="20"
                Padding="16">
            <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="MessageInput"
                     Watermark="TXT" />
            <Button Grid.Column="1"
                Margin="12,0,0,0"
                    x:Name="SendButton"
                    Content="Senden" />
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>